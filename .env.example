# Required - WDK Wallet
WDK_SEED=your twelve word bip39 seed phrase here

# Required - LLM (set at least one key)
# Supports any OpenAI-compatible API: Groq, OpenAI, Together, Fireworks, Ollama, etc.
GROQ_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
ANTHROPIC_API_KEY=

# Or use a universal key with custom base URL:
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://your-provider.com/v1
# LLM_MODEL=model-name

# Optional
# PLASMA_RPC=https://rpc.plasma.to
# PORT=3000
# HOST=0.0.0.0
