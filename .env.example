# ── Required ─────────────────────────────────────────────────

# BIP-39 seed phrase for WDK wallet (12 or 24 words)
# Must have test USDt + SepoliaETH (gas) on Sepolia testnet
WDK_SEED=your twelve word bip39 seed phrase here

# LLM Provider — set at least one, auto-detected in priority order
GROQ_API_KEY=                  # Free: https://console.groq.com (recommended, uses LLaMA 3.1 8B automatically)
# OPENAI_API_KEY=              # https://platform.openai.com/api-keys
# TOGETHER_API_KEY=            # https://api.together.xyz/settings/api-keys
# FIREWORKS_API_KEY=           # https://fireworks.ai/account/api-keys
# ANTHROPIC_API_KEY=           # https://console.anthropic.com/settings/keys (requires: npm install @anthropic-ai/sdk)

# ──────────────────────────────────────────────────────── OPTIONAL ─────────────────────────────────────────────────

# Custom OpenAI-compatible LLM provider
# LLM_API_KEY=
# LLM_BASE_URL=                # e.g. https://api.your-provider.com/v1
# LLM_MODEL=                   # e.g. llama-3.1-70b

# WDK Indexer API — enables on-chain transfer history
# Get key: https://wdk-api.tether.io/register
# WDK_INDEXER_API_KEY=

# x402 facilitator (required for x402 payment verification)
FACILITATOR_URL=https://facilitator.x402.org/

# Server config (defaults shown)
# PORT=4747
# HOST=0.0.0.0
# CHAIN_RPC=https://sepolia.drpc.org
