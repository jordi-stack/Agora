# Required - WDK Wallet
WDK_SEED=your twelve word bip39 seed phrase here

# Required - LLM Provider (set ONE of these)
GROQ_API_KEY=gsk_your_groq_api_key
# OPENAI_API_KEY=sk-your_openai_api_key
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Optional - LLM Model Override
# LLM_MODEL=llama-3.1-8b-instant

# Optional - State Persistence (recommended for production)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Optional - Chain Config (defaults shown)
# PLASMA_RPC=https://rpc.plasma.to
# PORT=3000
# HOST=0.0.0.0
# FACILITATOR_URL=https://x402.semanticpay.io/
